# ── Database ────────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (includes username, password, cluster URL, and DB name)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────────────────────────────
# Long random string used to sign JWT cookies — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_string

# ── Meta WhatsApp Cloud API ─────────────────────────────────────────────────────
# Found in Meta Developer Console → your app → WhatsApp → API Setup
META_PHONE_NUMBER_ID=your_phone_number_id
META_WABA_ID=your_whatsapp_business_account_id
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
