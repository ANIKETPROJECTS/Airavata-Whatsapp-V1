##############################################################################
# Airavata – nginx site config
# Place this file at: /etc/nginx/sites-available/airavataintelligence.com
# Then: sudo ln -s /etc/nginx/sites-available/airavataintelligence.com \
#                   /etc/nginx/sites-enabled/
##############################################################################

server {
    listen 80;
    server_name airavataintelligence.com www.airavataintelligence.com;

    # certbot will automatically upgrade this block to 443 when you run it
    # For now it just redirects everything to HTTPS after cert is issued
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name airavataintelligence.com www.airavataintelligence.com;

    # ── SSL (certbot fills these in automatically) ───────────────────────────
    ssl_certificate     /etc/letsencrypt/live/airavataintelligence.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/airavataintelligence.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # ── React static files ───────────────────────────────────────────────────
    root /var/www/airavata/artifacts/airavata/dist/public;
    index index.html;

    # SPA fallback – all frontend routes fall through to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── API + Webhook → Express on port 3014 ─────────────────────────────────
    location /api/ {
        proxy_pass         http://127.0.0.1:3014;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
